# ============================================================
# Environment variables — copy this file to .env and fill in
# your Azure credentials before running the project.
#
#   cp .env.example .env
#
# The actual credentials are shared separately (see README).
# Never commit the .env file — it is in .gitignore.
# ============================================================

# Azure Blob Storage connection string
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT_NAME;AccountKey=YOUR_ACCOUNT_KEY;EndpointSuffix=core.windows.net

# Airflow user ID — leave as 50000 on Mac/Linux
AIRFLOW_UID=50000
