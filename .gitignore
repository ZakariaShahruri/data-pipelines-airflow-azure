# Credentials — never commit these
.env
*/.env

# Python cache
__pycache__/
*/__pycache__/
*.pyc
*.pyo

# Virtual environments
airflow_env/
venv/
.venv/

# Pipeline outputs — keep folder structure via .gitkeep, ignore contents
output/*
!output/.gitkeep
*/output/*
!*/output/.gitkeep
output_zone/*
!output_zone/.gitkeep
*/output_zone/*
!*/output_zone/.gitkeep

# Airflow logs — keep folder structure via .gitkeep, ignore contents
logs/*
!logs/.gitkeep

# Input data files — too large to commit, download separately
input/*
!input/.gitkeep
*/input/*
!*/input/.gitkeep
input_zone/*.csv
input_zone/*.xlsx
input_zone/*.xls
*/input_zone/*.csv
*/input_zone/*.xlsx
*/input_zone/*.xls
!input_zone/archived/.gitkeep
!*/input_zone/archived/.gitkeep

# macOS
.DS_Store

# IDE
.idea/
.vscode/

